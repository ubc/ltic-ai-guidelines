# Sandboxed Claude Code, scoped to cwd.
# srt sets TMPDIR=/tmp/claude inside the sandbox automatically (see
# sandbox-runtime src/sandbox/sandbox-utils.ts:320-325) and auto-allows
# writes to /tmp/claude. Setting CLAUDE_CODE_TMPDIR here makes that
# explicit and gives each invocation its own subdir so concurrent ccx
# sessions don't trample each other's temp files.
#
# Shared body for ccx/ccx_permissive. The srt sandboxes deny
# ~/Library/Keychains, so claude's in-process
# `security find-generic-password` returns exit 44 and the keychain
# credential store is unreadable inside the sandbox. We seed claude's
# file-based credential store (~/.claude/.credentials.json) from the
# keychain out here, and claude falls back to it when the keychain read
# fails (fallbackStorage tries keychain first, file second). Unlike the
# old bare-token FD injection this carries the FULL credential — including
# subscriptionType/rateLimitTier — so claude picks the right default model
# and plan-mode agent count instead of degrading to the non-subscriber
# defaults the FD path forced (it hardcoded subscriptionType:null).
#
# We null the refreshToken before writing. The short-lived (~8h) access
# token is enough for a session; without a refresh token the sandbox can
# never refresh, which is deliberate on two counts:
#   1. The long-lived refresh token never touches disk — only the access
#      token does, and only for the life of the session.
#   2. Because the sandbox never refreshes, it never rotates the backend
#      refresh token, so the keychain stays valid and authoritative. No drift.
# When the access token expires, the session stops authenticating. Refresh
# it the normal way: exit, run `claude` once outside the sandbox (it
# refreshes silently against the keychain), then relaunch — which re-seeds
# the file from the now-fresh keychain.
#
# Seed on EVERY launch (overwrite). With no in-sandbox refresh the file
# can't renew itself, so the keychain is the source of truth and the file
# is just a per-launch snapshot of it. Seeding once would leave a stale,
# expired token.
#
# Concurrency: all ccx sessions share this one path and converge on the
# same keychain token, so the overwrite is a no-op in the common case. The
# write is atomic (temp file + rename) because claude re-reads the
# credential store mid-session — a plain `> file` truncates in place and a
# concurrent claude could read a half-written file. No cleanup-on-exit for
# the same reason: an rm could yank the file out from under a running
# session, and a stale expired token left between sessions is harmless
# (overwritten next launch).
_ccx_run() {
  local settings="$1"; shift
  local td="/tmp/claude/ccx-$$"
  mkdir -p "$td"
  chmod 700 "$td"

  # gh stores its token in the macOS keychain, which the sandbox denies. Pull
  # it out here so gh inside the sandbox can authenticate via $GH_TOKEN.
  local gh_token=""
  if command -v gh >/dev/null 2>&1; then
    gh_token=$(gh auth token 2>/dev/null)
  fi

  # A pure file-store user (no keychain entry) is left untouched: empty
  # cred_json skips the write. $$-suffixed temp keeps concurrent launches
  # from colliding on the scratch file; umask 077 closes the perms window so
  # the token is never briefly world-readable.
  local creds="$HOME/.claude/.credentials.json"
  local cred_json=""
  cred_json=$(security find-generic-password -a "$USER" -w -s "Claude Code-credentials" 2>/dev/null)
  if [[ -n "$cred_json" ]]; then
    local tmp="$creds.tmp.$$"
    if printf '%s' "$cred_json" | (umask 077; jq -c '.claudeAiOauth.refreshToken = null' > "$tmp"); then
      mv -f "$tmp" "$creds"
    else
      rm -f "$tmp"
    fi
  fi

  CLAUDE_CODE_TMPDIR="$td" \
  DISABLE_FEEDBACK_COMMAND=1 \
  CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 \
  GH_TOKEN="$gh_token" \
    srt --settings "$settings" -- claude "$@"
}

ccx()            { _ccx_run ~/.srt-claude-denyall.json "$@"; }
ccx_permissive() { _ccx_run ~/.srt-claude-allowall.json "$@"; }

# Tail / inspect macOS sandbox-exec denials. Pass a number for "last N
# minutes" of historical log; no argument streams live events.
srtlog() {
  local NOISE='ampdaemon|tccd|amfid|nsurlsessiond|cloudd|callservicesd|searchpartyuseragent|biomesyncd|knowledge-agent|appleaccountd|geod|locationd|mediaanalysisd|photoanalysisd|routined|trustd|symptomsd|networkserviceproxy|WebKit|sharingd|parsecd|imagent|identityservicesd|distnoted|UserEventAgent|coreduetd|contextstored|suggestd|powerd|bluetoothd'

  if [[ "$1" =~ ^[0-9]+$ ]]; then
    log show --style compact --last "${1}m" \
      --predicate 'sender == "Sandbox" OR process == "sandbox-exec"' \
      | grep -v -E "$NOISE"
  else
    log stream --style compact \
      --predicate 'sender == "Sandbox" OR process == "sandbox-exec"' \
      | grep --line-buffered -v -E "$NOISE"
  fi
}

# ONLY needed if you installed srt with `pnpm install -g .` instead of npm.
# pnpm puts its global binaries in a separate dir from nvm's node bin so
# they survive nvm switching, but that dir isn't on $PATH by default.
# `pnpm setup` writes this block automatically the first time you install
# pnpm — if it's already in your shell config you don't need it here.
#
# export PNPM_HOME="$HOME/Library/pnpm"
# case ":$PATH:" in
#   *":$PNPM_HOME/bin:"*) ;;
#   *) export PATH="$PNPM_HOME/bin:$PATH" ;;
# esac
